# ローカル開発で consumer.py を起動する際の環境変数テンプレート。
# 値を埋めて kafka/consumer/.env として保存する (リポジトリ管理外)。
# AWS アカウント ID やバケット名は CDK デプロイ先に合わせて差し替える。

# Structured Streaming の checkpointLocation 用 S3 バケット名 (s3a:// プレフィックス除く)。
# 命名規約: kafka-consumer-checkpoint-<アカウントID>-<env>
CHECKPOINT_BUCKET=kafka-consumer-checkpoint-<アカウントID>-dev

# PySpark 起動時の --packages / --conf。VS Code の envFile は単純な KEY=VALUE パーサで
# ${VAR} 展開を行わないため、warehouse の S3 Tables TableBucket ARN は直接埋め込む。
PYSPARK_SUBMIT_ARGS=--packages org.apache.iceberg:iceberg-spark-runtime-3.5_2.12:1.10.0,software.amazon.s3tables:s3-tables-catalog-for-iceberg-runtime:0.1.5,org.apache.spark:spark-protobuf_2.12:3.5.6,org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.6,org.apache.hadoop:hadoop-aws:3.4.1,software.amazon.awssdk:bundle:2.24.6 --conf spark.sql.extensions=org.apache.iceberg.spark.extensions.IcebergSparkSessionExtensions --conf spark.sql.catalog.s3tablesbucket=org.apache.iceberg.spark.SparkCatalog --conf spark.sql.catalog.s3tablesbucket.catalog-impl=software.amazon.s3tables.iceberg.S3TablesCatalog --conf spark.sql.catalog.s3tablesbucket.warehouse=arn:aws:s3tables:ap-northeast-1:<アカウントID>:bucket/kafka-events --conf spark.hadoop.fs.s3a.aws.credentials.provider=software.amazon.awssdk.auth.credentials.DefaultCredentialsProvider pyspark-shell
