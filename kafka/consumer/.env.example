# ローカル開発で consumer.py を起動する際の環境変数テンプレート。
# 値を埋めて kafka/consumer/.env として保存する (リポジトリ管理外)。
# AWS アカウント ID やバケット名は CDK デプロイ先に合わせて差し替える。

# S3 Tables の TableBucket ARN。Iceberg catalog の warehouse として渡す。
TABLE_BUCKET_ARN=arn:aws:s3tables:ap-northeast-1:<アカウントID>:bucket/kafka-events

# Structured Streaming の checkpointLocation 用 S3 バケット名 (s3a:// プレフィックス除く)。
# 命名規約: kafka-consumer-checkpoint-<アカウントID>-<env>
CHECKPOINT_BUCKET=kafka-consumer-checkpoint-<アカウントID>-dev
